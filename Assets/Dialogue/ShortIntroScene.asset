%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4a9e948b519b143298eab0cdd9b06378, type: 3}
  m_Name: ShortIntroScene
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTree
  sentences:
  - characterName: Bubea
    text: Let's wager somewhere in the middle.
    showCharacterSprite: 0
  - characterName: Margot
    text: One hundred?
    showCharacterSprite: 0
  - characterName: Bubea
    text: TEN THOUSAND!
    showCharacterSprite: 0
  - characterName: Bubea
    text: WOAH! Three-four.
    showCharacterSprite: 0
  - characterName: Bubea
    text: Does that mean we can triple or quadruple our wages, Mr. Bear?
    showCharacterSprite: 0
  - characterName: Bear Boris
    text: Yes, but please--
    showCharacterSprite: 0
  - characterName: Margot and Bubea
    text: (in unison) Four, four, four, four, four!
    showCharacterSprite: 0
  - characterName: Margot
    text: Aw, our cards don't hunt.
    showCharacterSprite: 0
  - characterName: Bubea
    text: 2 times! Go big or go home! Ace up my sleeve! Luck of the draw--
    showCharacterSprite: 0
  - characterName: Margot
    text: This ain't my first rodeo, buddy.
    showCharacterSprite: 0
  - characterName: Margot
    text: Our round's not over yet. There's nothing to worry 'bout.
    showCharacterSprite: 0
  - characterName: Bubea
    text: Is that good?
    showCharacterSprite: 0
  - characterName: Bear Boris
    text: I'm sorry. I'm so sorry, Mister Bunny.
    showCharacterSprite: 0
  - characterName: Margot
    text: Calm down, calm down, Bubea. It'll all be okay. It's a credit casino, remember?
    showCharacterSprite: 0
  - characterName: Dr. Hamm
    text: Hola.
    showCharacterSprite: 0
  - characterName: Margot
    text: Howdy Miste--
    showCharacterSprite: 0
  - characterName: Bubea
    text: I'M SORRY! PLEASE FORGIVE ME! I NEVER MEANT TO USE ALL OF YOUR MONEY! PLEASE
      GIVE ME ONE MORE CHANCE, I HAVE SO MANY RESEARCH PAPERS TO LIVE FOR!
    showCharacterSprite: 0
  - characterName: Bubea
    text: Plea--
    showCharacterSprite: 0
  - characterName: Dr. Hamm
    text: You're next, Ms. Marmot.
    showCharacterSprite: 0
  - characterName: Margot
    text: WHERE'S BUBEA!?
    showCharacterSprite: 0
  - characterName: Margot
    text: Wait, how ya know my last name?
    showCharacterSprite: 0
  - characterName: Dr. Hamm
    text: SILENCE. Your dear friend's debts have been passed onto you.
    showCharacterSprite: 0
  - characterName: Margot
    text: (wispers) Here we go again...
    showCharacterSprite: 0
  - characterName: Dr. Hamm
    text: You have until 12 AM to pay it all... or you'll be saying howdy to your
      dorky bunny friend!
    showCharacterSprite: 0
  - characterName: Dr. Hamm
    text: 'Your four little marmots. They''re watching TV and eating the neighbor''s
      grass. They''re next too! '
    showCharacterSprite: 0
  - characterName: Dr. Hamm
    text: Good luck.
    showCharacterSprite: 0
  - characterName: Margot
    text: I HAVE TO MAKE THEIR MONEY BY MIDNIGHT!
    showCharacterSprite: 0
